# Copie este arquivo para .env e preencha com seus valores reais.
# O arquivo .env NÃO deve ser commitado (está no .gitignore).

# Connection string do Neon (Postgres).
# Em produção (Vercel/serverless), use a URL COM POOLER (PgBouncer) — pegue em:
# Neon dashboard → seu projeto → Connection Details → marque "Pooled connection"
# e acrescente "&pgbouncer=true&connection_limit=1" no final.
# Exemplo (pooled): postgresql://USER:PASS@ep-xxx-pooler.region.aws.neon.tech/db?sslmode=require&pgbouncer=true&connection_limit=1
# Em dev local você pode usar a URL "direct" (sem pooler) — funciona dos dois jeitos.
DATABASE_URL="postgresql://user:password@host.neon.tech/dbname?sslmode=require"

# Segredo usado pra assinar tokens JWT.
# Gere um valor aleatório longo (ex: `openssl rand -base64 32`).
JWT_SECRET="troque-por-um-valor-aleatorio-longo"

# Porta do backend — só usada em dev local. Em serverless a Vercel ignora.
PORT=3001

# URL do frontend em produção (usado pra restringir CORS).
# Em dev, sem setar, a API libera http://localhost:5173.
# Ex em produção: https://seu-app.vercel.app
FRONTEND_URL=
